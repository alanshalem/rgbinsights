# Copy to .env and fill in. .env is git-ignored.
# NOTE: keep comments on their own lines. An inline comment after a value
# (e.g. `KEY=   # note`) can leak into the value with some .env parsers.

# --- Instagram credentials (only needed when USE_FAKE_INSTAGRAM=false) ---
IG_USERNAME=
IG_PASSWORD=

# Optional TOTP seed (base32) if the account has 2FA. Leave empty if none.
IG_2FA_SECRET=

IG_SESSION_FILE=session.json

# RECOMMENDED when login keeps hitting a checkpoint: reuse the `sessionid`
# cookie from a browser where you are already logged in (no API login flow,
# so no challenge). How to get it: log in at instagram.com in your browser ->
# F12 (DevTools) -> Application -> Cookies -> copy the value of `sessionid`.
# If set, it takes priority over user/password.
IG_SESSIONID=

# --- Anti-block hygiene (all optional) ---
# A stable proxy + consistent country/locale make the account look far less
# suspicious. Recommended if Instagram keeps asking for verification.
# Proxy example: http://user:pass@host:port  (one stable proxy, not rotating)
IG_PROXY=
IG_COUNTRY=
IG_LOCALE=

# --- Database ---
DATABASE_URL=sqlite:///./rgb.db

# --- Rate limiting / good behaviour ---
SCAN_MIN_DELAY_SECONDS=1
SCAN_MAX_DELAY_SECONDS=3
SCAN_MAX_REQUESTS=1500
RECENT_POSTS_LIMIT=50

# Keep true to run entirely on sample data (no Instagram). Set false to go live.
USE_FAKE_INSTAGRAM=true

# Data source: fake | web | playwright | instagrapi
#   playwright -> real logged-in headless browser (recommended; run app.login_browser once)
#   web        -> web API via IG_SESSIONID (only /users/* — not enough for DMs)
#   instagrapi -> mobile private API via user/password
# Empty falls back to USE_FAKE_INSTAGRAM.
IG_SOURCE=

# Playwright drives a plain Chrome over CDP (human login avoids the reCAPTCHA).
IG_BROWSER_DIR=.pw-profile        # dedicated Chrome profile (persists the login)
IG_BROWSER_HEADLESS=true          # headless when scraping; login is always headed
IG_CHROME_PATH=                   # path to chrome.exe; empty = auto-detect
IG_CDP_PORT=9222
