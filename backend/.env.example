# Copy to .env and fill in. .env is git-ignored.
# NOTE: keep comments on their own lines. An inline comment after a value
# (e.g. `KEY=value  # note`) can leak into the value with some .env parsers.

# =========================================================================
# Instagram: conectás pegando el `sessionid` desde la VENTANA de la app
# (chip IG -> "Pegá tu sesión"). Es lo más seguro: no hay login por API,
# así que IG no te pide challenge ni te flaguea la IP. El sessionid queda
# guardado en session.json y se reusa entre reinicios.
# =========================================================================

IG_SESSION_FILE=session.json

# Opcional: bootstrap por sessionid desde el .env en vez de la ventana.
# Dejalo vacío si conectás desde la app.
# Cómo sacarlo: instagram.com logueado -> F12 -> Application -> Cookies ->
# copiá el valor de `sessionid`.
IG_SESSIONID=

# --- Anti-block hygiene (opcional) ---
# Proxy estable (NO rotativo). Ej: http://user:pass@host:port
IG_PROXY=
# País/locale que matcheen la IP (default Argentina).
IG_COUNTRY=AR
IG_LOCALE=es_AR

# --- Database ---
DATABASE_URL=sqlite:///./rgb.db

# --- Rate limiting / good behaviour ---
SCAN_MIN_DELAY_SECONDS=1
SCAN_MAX_DELAY_SECONDS=3
SCAN_MAX_REQUESTS=1500
RECENT_POSTS_LIMIT=50

# false = Instagram real. true = datos de ejemplo (demo/dev).
USE_FAKE_INSTAGRAM=false

# Fuente de datos: fake | instagrapi
IG_SOURCE=instagrapi

# --- Legacy / DESACONSEJADO: login por user + password ---
# No recomendado: el login por API dispara challenges e IP-block. Preferí el
# sessionid. Si igual lo querés (auto-renovación de sesión), descomentá y
# completá los tres:
# IG_USERNAME=
# IG_PASSWORD=
# IG_2FA_SECRET=
